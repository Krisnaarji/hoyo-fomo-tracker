[Unit]
Description=HoYo FOMO Tracker FastAPI Service
After=network-online.target
Wants=network-online.target

[Service]
User=nasana
WorkingDirectory=/home/nasana/hoyo-tracker
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/nasana/hoyo-tracker/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8123
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
